ENV=dev
LOG_LEVEL=INFO
REPO_NAME=performance_hub

POSTGRES_HOST=your-postgres-host
POSTGRES_PORT=5432
POSTGRES_DB=your-database
POSTGRES_USER=your-user
POSTGRES_PASSWORD=
POSTGRES_LOCK_TIMEOUT_MS=30000
POSTGRES_STATEMENT_TIMEOUT_MS=1800000
POSTGRES_BOOTSTRAP_LOCK_TIMEOUT_MS=600000
POSTGRES_BOOTSTRAP_STATEMENT_TIMEOUT_MS=3600000
POSTGRES_BOOTSTRAP_LOCK_RETRY_ATTEMPTS=6
POSTGRES_BOOTSTRAP_LOCK_RETRY_SLEEP_SECONDS=10
POSTGRES_GOLD_STATEMENT_TIMEOUT_MS=0
POSTGRES_SILVER_STATEMENT_TIMEOUT_MS=0

POSTGRES_SCHEMA_RAW=raw
POSTGRES_SCHEMA_BRONZE=bronze
POSTGRES_SCHEMA_SILVER=silver
POSTGRES_SCHEMA_GOLD=gold

STORAGE_ROOT=./storage
MANIFEST_ROOT=./storage/manifests
FAILED_ROOT=./storage/failed
ARCHIVE_ROOT=./storage/archive
PROVIDERS_CONFIG_ROOT=./config/providers

DEFAULT_PAGE_SIZE=100
REQUEST_TIMEOUT_SECONDS=60

# Catapult API keys
CATAPULT_BASE_URL=https://connect-eu.catapultsports.com/api/v6
CATAPULT_A_API_KEY=
CATAPULT_B_API_KEY=
CATAPULT_U15_API_KEY=
CATAPULT_U16_API_KEY=
CATAPULT_U17_API_KEY=
CATAPULT_U19_API_KEY=
CATAPULT_FEMININO_API_KEY=

# VALD
VALD_CLIENT_ID=
VALD_CLIENT_SECRET=
# Deprecated endpoint. Migrate to https://security.valdperformance.com/connect/token
# once VALD re-issues client credentials for the new identity server.
VALD_TOKEN_URL=https://auth.prd.vald.com/oauth/token
VALD_REGION=eu
VALD_TENANT_ID=
VALD_TEAM_ID=

# VALD product base URLs (direct overrides)
VALD_FD_BASE_URL=
VALD_FF_BASE_URL=
VALD_ND_BASE_URL=
VALD_SS_BASE_URL=
VALD_TENANTS_BASE_URL=
VALD_PROFILES_BASE_URL=

# Airflow / Docker
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=
AIRFLOW__WEBSERVER__SECRET_KEY=
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=
